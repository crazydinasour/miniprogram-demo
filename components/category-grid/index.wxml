<view class="container">
    <l-grid class="inner-container">
        <block wx:for="{{grid}}">
            <l-grid-item key="{{index}}" slot="{{index}}">
                <view class="grid-item">
                    <image class="img" src="{{item.img}}"></image>
                    <text src="{{item.title}}"></text>
                </view>
            </l-grid-item>
        </block>
    </l-grid>
</view>