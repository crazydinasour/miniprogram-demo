<!--pages/home/home.wxml-->
<view>
    <image class="themeA" src="{{themeA.entrance_img}}"></image>
    <swiper class="swiper-img" indicator-dots="true" autoplay="true" circular="true">
        <block wx:for="{{bannerB.items}}">
            <swiper-item>
                <image class="swiper-img" src="{{item.img}}" ></image>
            </swiper-item>
        </block>
    </swiper>
    <s-category-grid grid="{{grid}}"></s-category-grid>
    <image class="activity" src="{{activityD.entrance_img}}"></image>
</view>